# macOS
.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp

# Orchestrator runtime state (only relevant when the kit is installed into
# a target repo, but listed here for hygiene if anyone runs it from a
# clone of this source repo).
/.claude/state/orchestrator.lock/
/.claude/state/run-*.json
/.claude/state/orchestrator.log
/.claude/state/orchestrator.log.*
/.claude/state/notifications.log

# Additional orchestrator runtime state (added at v2 install)
/.claude/state/post-merge-pr*.log
/.claude/state/active_worktrees.txt
/.claude/state/tick-wrapper.log

# Orchestrator plan runtime state — written and updated by workers each
# tick; should never be tracked. The plan markdowns under .claude/plans/
# stay tracked (operator-authored content), only the state files are
# excluded.
.claude/plans/*.state.json
.claude/plans/archive/*.state.json

# Claude Code's own runtime (not orchestrator-kit related)
.claude/scheduled_tasks.lock
.claude/worktrees/
